{
  "name": "setsaga",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "packageManager": "pnpm@10.25.0",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@shopify/react-native-skia": "2.6.2",
    "drizzle-orm": "^0.45.2",
    "expo": "~57.0.6",
    "expo-constants": "~57.0.3",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.6",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "victory-native": "^41.26.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "babel-plugin-inline-import": "^3.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.1",
    "prettier": "^3.9.4",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "db:generate": "drizzle-kit generate"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@shopify/react-native-skia"
    ]
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "collectCoverageFrom": [
      "lib/game/**/*.ts",
      "lib/dates.ts"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 90,
        "branches": 90,
        "functions": 90,
        "lines": 90
      }
    }
  },
  "private": true
}
